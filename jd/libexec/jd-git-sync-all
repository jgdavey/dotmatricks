#!/usr/bin/env bb
;; Usage: jd git-sync-all [opts]
;; Summary: Sync all tracking branches for repos
;; Help: Iterates through all local branches that have remote tracking branches
;; and attempts to fast-forward them to match their upstream counterparts.

(require '[babashka.process]
         '[babashka.deps :as deps]
         '[babashka.fs :as fs]
         '[clojure.string :as str])

#_{:clj-kondo/ignore [:unresolved-namespace]}
(babashka.classpath/add-classpath (str (System/getenv "_JD_ROOT") "/share/lib"))

;; --complete is supported
;; --help is supported
(require '[jd.common :as common])

(deps/add-deps
 '{:deps {com.joshuadavey/crockery {:mvn/version "0.3.3"}
          de.timokramer/charm.clj {:mvn/version "0.1.60"}}})

(require '[crockery.core :as crock]
         '[charm.core :as charm]
         '[charm.components.spinner :as spinner])

(defn repo-root [cli-passed]
  (-> (or cli-passed
          (System/getenv "SOURCE_DIR") ;; Uses init.sh
          (str (System/getenv "_JD_ROOT") "/../.."))
      fs/path
      fs/canonicalize))

(defn known-repos [root-dir]
  (map (fn [p]
          (let [path (fs/parent p)]
            {:dir (str path)
             :repo (str (fs/relativize root-dir path))}))
        (fs/glob root-dir "*/.git" {:max-depth 2
                                    :hidden true})))

;;--- Git operations ---

(def ^:dynamic *dir* nil)

(defn git-cmd
  "Execute a git command and return {:success? :out :err :exit}"
  [& args]
  (common/process-run-sync (into ["git"] args) {:dir *dir*}))

(defn git-cmd-output
  "Execute a git command, returning trimmed stdout on success, nil on failure."
  [& args]
  (let [{:keys [out success?]} (apply git-cmd args)]
    (when success?
      (str/trim out))))

(defn current-branch
  "Get the name of the current branch"
  []
  (git-cmd-output "rev-parse" "--abbrev-ref" "HEAD"))

(defn rev-parse
  [ref]
  (git-cmd-output "rev-parse" "-q" ref))

(defn dirty?
  "Check if working tree has uncommitted changes"
  []
  (let [{:keys [out success?]} (git-cmd "status" "--porcelain")]
    (and success? (not (str/blank? out)))))

(defn get-tracking-branches
  "Get all local branches with their remote tracking branches.
   Returns a seq of maps: [{:local 'main' :remote 'origin/main'} ...]"
  []
  (let [{:keys [out success?]} (git-cmd "for-each-ref"
                                        "--format=%(refname:short)|%(upstream:short)"
                                        "refs/heads")]
    (if success?
      (into [] (comp (map str/trim)
                     (remove str/blank?)
                     (keep (fn [line]
                             (let [[local remote] (str/split line #"\|" 2)]
                               (when (and local remote (not (str/blank? remote)))
                                 {:local local
                                  :remote remote})))))
            (str/split-lines out))
      [])))

(defn local-remote-status
  "Check if local branch can be fast-forwarded to remote"
  [{:keys [local remote]}]
  (let [local-sha (rev-parse local)
        remote-sha (rev-parse remote)
        base {:local local
              :local-sha local-sha
              :remote remote
              :remote-sha remote-sha}]
    (if remote-sha
      (let [{rev-list-okay? :success? out :out} (git-cmd "rev-list" "--left-right" "--count"
                                                         (str local "..." remote))]
        (if rev-list-okay?
          (let [[ahead behind] (map parse-long (str/split (str/trim out) #"\s+"))]
            (merge base
                   {:branch-status :tracking
                    :can-ff? (and (pos? behind) (zero? ahead))
                    :ahead ahead
                    :behind behind
                    :up-to-date? (and (zero? behind) (zero? ahead))}))
          (assoc base :error? true
                 :message "unknown error getting rev-list")))
      (assoc base :remote-gone? true))))

;;--- Branch sync logic ---

(defn get-branch-sync-status
  "Sync a single branch by checking it out and pulling with --ff-only.
   Returns {:success? :status :message}"
  [{:keys [current dirty?] :as opts}]
  (let [{:keys [local remote] :as status} (local-remote-status opts)]
    (cond
      ;; Branch is already up to date
      (:up-to-date? status)
      (assoc status :status :up-to-date)

      ;; Branch can be fast-forwarded
      (:can-ff? status)
      (if (= current local)
        (if dirty?
          (assoc status
                 :status :unable-to-ff
                 :message "branch has files that are not checked-in")
          (assoc status
                 :status :sync
                 :command :sync/current
                 :git-args ["merge" "--ff-only" remote]))
        (assoc status
               :status :sync
               :command :sync/other
               :git-args ["update-ref" (str "refs/heads/" local) remote]))

      ;; Previously tracked branch no longer present in remote
      (:remote-gone? status)
      (if (= current local)
        (assoc status
               :status :remote-gone
               :message "remote branch is gone, but still checked out locally")
        (assoc status
               :status :sync
               :command :sync/delete-branch
               :git-args ["branch" "-D" local]))

      ;; Some other error
      (:error? status)
      (assoc status
             :message (or (:message status) "unknown error")
             :status :error)

      ;; Diverged
      :else
      (let [behind (:behind status 0)
            ahead (:ahead status 0)]
        (assoc status
               :status :diverged
               :message (str "cannot fast-forward (behind: " behind ", ahead: " ahead ")"))))))

(defn sync-all-branches
  "Sync all tracking branches and return results"
  [{:keys [dry-run?]}]
  (let [current (current-branch)
        branches (get-tracking-branches)
        dirty? (dirty?)
        fetch-result (if dry-run?
                       {:success? true}
                       (git-cmd "fetch" "--all" "--prune" "-P" "--force"))]
    (if (:success? fetch-result)
      (let [;; Get sync actions and statuses
            statuses (mapv (fn [{:keys [local remote]}]
                             (get-branch-sync-status {:local local
                                                      :remote remote
                                                      :dry-run? dry-run?
                                                      :dirty? dirty?
                                                      :current current}))
                           branches)
            ;; Do the sync actions
            results (if dry-run?
                      statuses
                      (mapv (fn [status]
                              (if (= :sync (:status status))
                                (let [{:keys [success? out]} (apply git-cmd (:git-args status))
                                      _ (when (and success? (= :sync/current (:status status)))
                                          (git-cmd "submodule" "update" "--init"))]
                                  (if success?
                                    status
                                    (assoc status :status :error
                                           :message (str "Error while syncing:\n" out))))
                                status))
                            statuses))]
        {:success? true
         :dir *dir*
         :results results})
      {:success? false
       :dir *dir*
       :message (str "Fetch failed " (:err fetch-result))})))

;;--- UI / rendering ---

(defmulti output-spec :status)

(defmethod output-spec :up-to-date [_]
  {:symbol "="
   :color :green})

(defmethod output-spec :sync [{:keys [local-sha remote-sha command]}]
  (if (= :sync/delete-branch command)
    {:symbol "♺"
     :color :green
     :detail "(removed)"}
    {:symbol "✓"
     :color :green
     :detail (str
              (subs (or local-sha "") 0 7)
              ".."
              (subs (or remote-sha "") 0 7))}))

(defmethod output-spec :diverged [{:keys [message]}]
  {:symbol "!"
   :color :yellow
   :detail message})

(defmethod output-spec :remote-gone [{:keys [message]}]
  {:symbol "ø"
   :color :red
   :detail message})

(defmethod output-spec :unable-to-ff [{:keys [message]}]
  {:symbol "!"
   :color :yellow
   :detail message})

(defmethod output-spec :error [{:keys [message]}]
  {:symbol "✗"
   :color :red
   :detail message})

(defn print-summary
  "Print a summary of sync results"
  [results dry-run?]
  (println)
  (println)
  (println (common/colorize :bold
                            (if dry-run?
                              "Dry run - would sync the following branches:"
                              "Sync results:")))
  (println)
  (crock/print-table
   {:titles? false
    :defaults {:ignore-ansi? true}
    :format :plain}
   (into [] (comp
             (map :results)
             cat
             (remove (fn [{:keys [status]}] (= :up-to-date status)))
             (map (fn [result]
                    (let [{:keys [symbol detail color]} (output-spec result)
                          branch-name (:local result)
                          repo (common/colorize :bold (:repo result))
                          summary (common/colorize color (str symbol " " branch-name))]
                      {:repo repo
                       :branch summary
                       :details detail}))))
         results)))

;;--- State management / charm program ---

(defn init-state [opts]
  (let [repos (mapv #(assoc % :state :queued)
                    (known-repos (repo-root (:root opts))))]
    {:opts {:dry-run? (:dry-run opts)
            :threads (:threads opts)
            :root (:root opts)}
     :repos repos
     :repo->idx (into {} (map-indexed (fn [i {:keys [repo]}] [repo i])) repos)}))

(defn complete?
  [r]
  (= :complete (:state r)))

(defn queued?
  [r]
  (= :queued (:state r)))

(defn running?
  [r]
  (= :running (:state r)))

(defn all-done?
  [{:keys [repos]}]
  (every? complete? repos))

(defn complete-percent [repos]
  (/
   (count (filter complete? repos))
   (float (count repos))))

(def complete-style
  (charm/style :fg charm/green :bold true))

(def hint-style
  (charm/style :fg 240))

(defn render-bar
  "Render a single progress bar with label."
  [{:keys [repos window-size]}]
  (let [bar (charm/progress-bar :width (or (some-> window-size :width (* 0.75) long) 60)
                                :bar-style {:full "━" :empty "┈"}
                                ;; :bar-style :thin
                                :show-percent false
                                :percent (complete-percent repos))]
    (str " "
         (charm/progress-view bar)
         " "
         (count (filter complete? repos))
         "/"
         (count repos))))

(defn render-repo [repo]
  (case (:state repo)
    :queued
    (str "   "
         (charm/render (charm/style :fg 238) (:repo repo)))

    :running
    (str " " (charm/spinner-view (:spinner repo)) " "
         (charm/render (charm/style :fg charm/cyan :bold true) (:repo repo)))

    :complete
    (str " ✓ "
         (charm/render (charm/style :fg charm/green) (:repo repo)))))

(defn visible-repos [repos size]
  (let [running-idx (or (first (keep-indexed (fn [i r] (when (running? r) i))
                                             repos))
                        0)
        queued-idx (or (first (keep-indexed (fn [i r] (when (queued? r) i))
                                            repos))
                       (count repos))
        upper (min (inc (max queued-idx size)) (count repos))
        lower (min running-idx (max 0 (- upper size)))]
    (subvec repos lower upper)))

(defn view [state]
  (let [{:keys [repos opts]} state]
    (cond
      (all-done? state)
      (str "\n" (charm/render complete-style
                         (format "✓ Finished syncing %s repos" (count repos))) "\n\n")

      :else
      (str (render-bar state)
           "\n"
           (str/join "\n"
                     (->> (visible-repos repos (max 10 (+ 4 (:threads opts))))
                          (map render-repo)))))))

(defn complete-repo [m]
  (assoc m :type :complete-repo))

(defn make-repo-task
  "Create a changeset entry for starting sync on a repo."
  [opts repo->idx item]
  (let [repo (:repo item)
        [spinner cmd] (charm/spinner-init (charm/spinner :dots :id repo))]
    {:path [:repos (get repo->idx repo)]
     :updated (assoc item :state :running :spinner spinner)
     :cmds [cmd
            (charm/cmd (fn []
                         (let [{:keys [repo dir]} item]
                           (binding [*dir* dir]
                             (let [{:keys [success?] :as ret} (sync-all-branches opts)
                                   results (map #(assoc % :repo repo) (:results ret))]
                               (complete-repo
                                (if success?
                                  {:success? true
                                   :repo repo
                                   :results results}
                                  {:success? false
                                   :repo repo
                                   :error (:message ret)})))))))]}))

(defn update-state [state msg]
  (let [running-repos (filter running? (:repos state))
        waiting-repos (filter queued? (:repos state))]
    (cond
      (all-done? state)
      [state charm/quit-cmd]

      ;; Repo finished
      (= :complete-repo (:type msg))
      (let [{:keys [repo->idx]} state
            path [:repos (get repo->idx (:repo msg))]]
        [(-> state
             (update-in path merge msg)
             (update-in path assoc :state :complete))
         nil])

      (charm/window-size? msg)
      [(assoc state :window-size msg) (charm/cmd (fn [] {:type :continue}))]

      ;; Start downloading (n threads) repos
      (and (< (count running-repos) (get-in state [:opts :threads]))
           (seq waiting-repos))
      (let [{:keys [opts repo->idx]} state
            needed (- (get-in state [:opts :threads]) (count running-repos))
            items (take needed waiting-repos)
            changeset (mapv #(make-repo-task opts repo->idx %) items)]
        [(reduce (fn [s c] (assoc-in s (:path c) (:updated c))) state changeset)
         (apply charm/batch (mapcat :cmds changeset))])

      ;; continue spinner animation
      (spinner/tick-msg? msg)
      (let [{:keys [spinner-id]} msg
            r->i (:repo->idx state)
            path [:repos (r->i spinner-id) :spinner]
            spinner (get-in state path)
            [new-spinner cmd] (charm/spinner-update spinner msg)]
        [(assoc-in state path new-spinner) cmd])

      :else
      [state nil])))

;;--- CLI entry point ---
(def cli-handler
  (common/build-cli-args-handler
   {:description (str "p git-sync - Sync all tracking branches in a git repository\n\n"
                      "This command will iterate through all local branches with remote\n"
                      "tracking branches and attempt to fast-forward them to match upstream.\n\n"
                      "Examples:\n"
                      "  p git-sync-all                    # Sync all tracking branches\n"
                      "  p git-sync-all --dry-run          # Preview what would be synced\n")
    :allow-no-args? true
    :cli-options [["-n" "--dry-run" "Show what would be synced without making changes"]
                  ["-j" "--threads THREADS" "Number of threads to use (with --all)"
                   :default 5
                   :parse-fn parse-long
                   :validate [#(< 0 % 20) "Must be a number between 0 and 20"]]
                  ["-r" "--root" "Override root directory for repositories"]]}))

(defn main [args]
  (let [{:keys [options errors]} (cli-handler args)]
    (when (seq errors)
      (println "ERROR:")
      (doseq [e errors]
        (println e))
      (System/exit (count errors)))
    (->
     (charm/run {:view view
                 :update update-state
                 :init #(init-state options)})
     :repos
     (print-summary (:dry-run options)))))

;; Run main if this script is executed directly
(when (common/run-main?)
  (main *command-line-args*))
